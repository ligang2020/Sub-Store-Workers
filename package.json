{
    "name": "sub-store-workers",
    "version": "1.0.0",
    "description": "Sub-Store Cloudflare Workers Adapter",
    "type": "module",
    "scripts": {
        "dev": "vite dev --host 0.0.0.0 --port 3000",
        "build": "vite build",
        "preview": "vite preview --host 0.0.0.0 --port 3000",
        "deploy:local": "npx wrangler deploy",
        "deploy:action": "set -o pipefail && npx wrangler deploy 2>&1 | sed -e '/workers.dev/d' -e '/https:\\/\\//d'",
        "tail": "npx wrangler tail --format=pretty"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "^1.18.0",
        "@vitejs/plugin-react": "^5.1.2",
        "vite": "^7.3.0",
        "wrangler": "^4.0.0"
    },
    "dependencies": {
        "@marsidev/react-turnstile": "^1.4.0",
        "jose": "^6.1.3",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "react-router-dom": "^7.11.0"
    }
}